{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "rootDir": ".",
    "types": ["node", "electron"],
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["main.ts", "preload.ts", "utils/**/*.ts", "shared/**/*.ts"]
}
